{
  "name": "promotion-approval-server",
  "version": "1.0.0",
  "description": "PromoDash API — Express + Prisma + PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "npx prisma migrate deploy",
    "db:reset": "psql $DATABASE_URL -f prisma/migrations/001_init.sql && psql $DATABASE_URL -f prisma/migrations/002_seed.sql",
    "db:studio": "npx prisma studio",
    "prisma:generate": "npx prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^5.13.0"
  }
}
